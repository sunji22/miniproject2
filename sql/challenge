    ) AS description,

    -- 3. 보증금 및 인증 횟수
    (1 + (n % 5)) * 10000 AS deposit_amount, -- 10,000원 ~ 50,000원
    3 + (n % 5) AS required_count,           -- 3회 ~ 7회

    -- 4. 진행 기간 (현재 날짜 기준)
    CURRENT_DATE - INTERVAL (n % 30) DAY AS start_date,
    CURRENT_DATE + INTERVAL (7 + (n % 14)) DAY AS end_date,

    -- 5. 챌린지 상태 (RECRUITING, ONGOING, CLOSED)
    CASE 
        WHEN n % 3 = 0 THEN 'RECRUITING'
        WHEN n % 3 = 1 THEN 'ONGOING'
        ELSE 'CLOSED'
    END AS status,

    -- 6. 정산 상태 (PENDING, SETTLED)
    -- CLOSED 상태 중 짝수 번째만 SETTLED, 그 외(RECRUITING, ONGOING 포함)는 PENDING
    CASE 
        WHEN (n % 3 = 2) AND (n % 2 = 0) THEN 'SETTLED'
        ELSE 'PENDING'
    END AS settlement_status,

    -- 7. 기타 연관 정보
    1 + (n % 5) AS host_id,                  -- host_id 1~5 순환
    NOW() - INTERVAL (n % 30) DAY AS created_at
FROM seq;